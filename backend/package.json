{
  "name": "roamio-backend",
  "version": "1.0.0",
  "description": "Roamio API — Express + Prisma + Firebase Auth + Anthropic AI",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node prisma/seed.js",
    "db-setup": "npx prisma db push --accept-data-loss",
    "build": "npx prisma generate && npm run db-setup && node prisma/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.2.0",
    "groq-sdk": "^1.1.2",
    "prisma": "^5.22.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
