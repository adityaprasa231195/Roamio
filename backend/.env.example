# Traveloop Backend — Environment Variables

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Anthropic AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Firebase Admin ---
# Paste the entire service account JSON as a single-line string
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"...","client_email":"..."}

# --- Server ---
PORT=3001

# --- Dev Mode (set to true to bypass Firebase auth — for local testing without Firebase) ---
DEV_AUTH_BYPASS=true
